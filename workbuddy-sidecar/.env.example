# WorkBuddy Sidecar 配置

# 监听端口（默认 9876）
WORKBUDDY_SIDECAR_PORT=9876

# 监听地址（默认仅本地，生产环境保持 127.0.0.1）
WORKBUDDY_SIDECAR_HOST=127.0.0.1

# API Key（可选 — 如果已通过 codebuddy CLI 登录则自动复用）
# CODEBUDDY_API_KEY=your-api-key-here

# 中国版用户需要设置：
# CODEBUDDY_INTERNET_ENVIRONMENT=internal

# iOA 版用户需要设置：
# CODEBUDDY_INTERNET_ENVIRONMENT=ioa
